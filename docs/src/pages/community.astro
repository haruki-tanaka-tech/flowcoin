---
import Base from '../layouts/Base.astro';

const channels = [
  {
    name: 'Telegram',
    handle: '@flowcoin',
    url: 'https://t.me/flowcoin',
    desc: 'Announcements, release notes, and informal discussion.',
    icon: 'telegram',
  },
  {
    name: 'GitHub Discussions',
    handle: 'KristianPilatovich/flowcoin/discussions',
    url: 'https://github.com/KristianPilatovich/flowcoin/discussions',
    desc: 'Design questions, feature proposals, technical deep-dives.',
    icon: 'github',
  },
  {
    name: 'GitHub Issues',
    handle: 'KristianPilatovich/flowcoin/issues',
    url: 'https://github.com/KristianPilatovich/flowcoin/issues',
    desc: 'Bug reports and concrete, actionable work items.',
    icon: 'issue',
  },
];
---

<Base title="Community — FlowCoin">
  <section class="page-hero">
    <div class="container">
      <div class="eyebrow">Community</div>
      <h1>Join the conversation.</h1>
      <p class="lead">
        FlowCoin is a young project. No foundation, no marketing department,
        no paid community managers — just people who believe CPU mining
        deserves a Bitcoin-grade chain underneath it.
      </p>
    </div>
  </section>

  <section class="container channels">
    {channels.map(ch => (
      <a href={ch.url} class="ch" rel="noopener">
        <div class="ch-icon">
          {ch.icon === 'telegram' && (
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M21.5 3.5L2.5 10.5l5.5 2 2 6.5 3-3.5 5 4 3.5-16zM10 13.5l8-7-6 8.5" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
          )}
          {ch.icon === 'github' && (
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2C6.5 2 2 6.5 2 12c0 4.4 2.9 8.2 6.8 9.5.5.1.7-.2.7-.5v-1.7c-2.8.6-3.4-1.3-3.4-1.3-.5-1.2-1.1-1.5-1.1-1.5-.9-.6.1-.6.1-.6 1 .1 1.6 1 1.6 1 .9 1.5 2.3 1.1 2.9.8.1-.6.4-1.1.6-1.4-2.2-.3-4.5-1.1-4.5-5 0-1.1.4-2 1-2.7-.1-.3-.5-1.3.1-2.7 0 0 .8-.3 2.7 1 .8-.2 1.7-.3 2.5-.3.9 0 1.7.1 2.5.3 1.9-1.3 2.7-1 2.7-1 .5 1.4.2 2.4.1 2.7.6.7 1 1.6 1 2.7 0 3.9-2.3 4.7-4.5 5 .4.3.7.9.7 1.8v2.7c0 .3.2.6.7.5C19.1 20.2 22 16.4 22 12c0-5.5-4.5-10-10-10z" fill="currentColor"/></svg>
          )}
          {ch.icon === 'issue' && (
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.6"/></svg>
          )}
        </div>
        <div class="ch-body">
          <h3>{ch.name}</h3>
          <p class="handle mono">{ch.handle}</p>
          <p class="desc">{ch.desc}</p>
        </div>
        <svg class="arrow" width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 11L11 3M11 3H4.5M11 3V9.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </a>
    ))}
  </section>

  <section class="container contributing">
    <h2>Contributing</h2>
    <p class="lead">
      The project welcomes patches, reviews, documentation edits, and
      translations. If you are new to the codebase:
    </p>

    <div class="contrib-steps">
      <div class="cs">
        <h4>1. Read the spec</h4>
        <p>Start with <a href="/documentation">the protocol doc</a> and the architecture overview before touching consensus code.</p>
      </div>
      <div class="cs">
        <h4>2. Run the tests</h4>
        <p><code>./build/flowcoin_tests</code> — 55 groups covering crypto, consensus, P2P, wallet. Keep them green.</p>
      </div>
      <div class="cs">
        <h4>3. Open a PR</h4>
        <p>Small, focused, with a rationale. Consensus-breaking changes need a discussion thread first.</p>
      </div>
    </div>
  </section>

  <section class="container principles">
    <h2>Principles</h2>
    <ul>
      <li><strong>No premine, no ICO, no treasury.</strong> Every coin is mined from genesis on. No developer allocation. No "foundation" that owns 10% of supply.</li>
      <li><strong>Consensus is forever.</strong> Breaking consensus changes require overwhelming justification. The default answer is "don't".</li>
      <li><strong>Bitcoin-compatible where possible.</strong> Reusing Bitcoin's tooling, wire formats, and economic model reduces the attack surface and accelerates adoption.</li>
      <li><strong>CPU mining is a feature, not a phase.</strong> If an ASIC ever ships, we change the seed / parameters to break it. Mining accessibility is non-negotiable.</li>
      <li><strong>Code over rhetoric.</strong> Promises don't secure the chain — running nodes and tested code do.</li>
    </ul>
  </section>
</Base>

<style>
  .page-hero {
    padding: 4rem 0 2rem;
    border-bottom: 1px solid var(--border);
  }

  .eyebrow {
    color: var(--accent);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.75rem;
  }

  .lead {
    font-size: 1.1rem;
    max-width: 640px;
    line-height: 1.6;
  }

  .channels {
    margin-top: 3rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .ch {
    display: grid;
    grid-template-columns: 48px 1fr 14px;
    align-items: center;
    gap: 1rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    color: var(--text);
    transition: border-color 120ms ease;
  }

  .ch:hover {
    border-color: var(--border-strong);
    color: var(--text);
  }

  .ch-icon {
    width: 48px;
    height: 48px;
    background: var(--accent-soft);
    color: var(--accent);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ch h3 {
    font-size: 1.05rem;
    margin-bottom: 0.125rem;
  }

  .ch .handle {
    font-size: 0.85rem;
    color: var(--text-dim);
    margin-bottom: 0.375rem;
  }

  .ch .desc {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .ch .arrow {
    color: var(--text-dim);
    transition: transform 120ms ease, color 120ms ease;
  }

  .ch:hover .arrow {
    color: var(--accent);
    transform: translate(2px, -2px);
  }

  .contributing {
    margin-top: 5rem;
  }

  .contributing h2 { margin-bottom: 1rem; }

  .contrib-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 2rem;
  }

  .cs {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
  }

  .cs h4 {
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }

  .cs p {
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .principles {
    margin-top: 5rem;
  }

  .principles h2 { margin-bottom: 1.25rem; }

  .principles ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .principles li {
    padding: 1rem 1.25rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.55;
  }

  .principles strong {
    color: var(--text);
    font-weight: 600;
  }

  @media (max-width: 720px) {
    .contrib-steps { grid-template-columns: 1fr; }
    .ch { grid-template-columns: 40px 1fr 14px; padding: 1rem; }
    .ch-icon { width: 40px; height: 40px; }
  }
</style>
